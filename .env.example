# Local MongoDB URI (for development)
MONGO_URI=mongodb://localhost:27017/localdb

# Remote MongoDB URI (for production/remote database)
# Example: mongodb+srv://<username>:<password>@cluster0.example.mongodb.net/dbname?retryWrites=true&w=majority
REMOTE_MONGO_URI=mongodb+srv://<username>:<password>@cluster0.example.mongodb.net/patent-act?retryWrites=true&w=majority

# Server configuration
PORT=5000

# Flask debug mode
FLASK_DEBUG=False

# Flask secret key for session management (multi-user support)
# Generate a random key with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your_secret_key_here_generate_a_random_one_for_production

# OpenAI/OpenRouter API configuration
OPENROUTER_API_KEY=your_api_key_here
OPENROUTER_MODEL=anthropic/claude-3-opus